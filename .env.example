# ===============================
# Backend container configuration
# ===============================
NODE_ENV=production
TZ=UTC
PORT=3000
HOST_PORT=3010
CONTAINER_NAME=lectura-aumentada-backend
IMAGE_NAME=lectura-aumentada-backend

# ===============================
# MongoDB configuration (Option A)
# Preferred when password has special chars: use full URI URL-encoded
# Example password: P@ss/w:rd -> P%40ss%2Fw%3Ard
# ===============================
MONGODB_URI=mongodb://168.231.71.181:27017/Lectura_Aumentada_DB

# ===============================
# MongoDB configuration (Option B)
# If MONGODB_URI is empty, app builds URI from these vars.
# USER/PASSWORD are optional.
# ===============================
MONGODB_HOST=168.231.71.181
MONGODB_PORT=27017
MONGODB_DB=Lectura_Aumentada_DB
MONGODB_USER=
MONGODB_PASSWORD=

# ===============================
# JWT (required at runtime; min 32 chars; no placeholder values)
# ===============================
JWT_SECRET=pon_aqui_un_secreto_largo_de_32_o_mas_caracteres
JWT_EXPIRES_IN=1d
UPLOADS_DIR=uploads

# Comma-separated browser origins (production). In development, CORS defaults to permissive if unset.
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===============================
# Demo auth/content for local-dev (opt-in; defaults are false in code)
# ===============================
AUTH_DEMO_SEED_ENABLED=false
DEMO_CONTENT_SEED_ENABLED=false
DEMO_STUDENT_EMAIL=student@lectura.app
DEMO_STUDENT_PASSWORD=Lectura123!
DEMO_STUDENT_DISPLAY_NAME=Demo Student
DEMO_STUDENT_TWO_EMAIL=student2@lectura.app
DEMO_STUDENT_TWO_PASSWORD=Lectura123!
DEMO_STUDENT_TWO_DISPLAY_NAME=Demo Student 2
DEMO_TEACHER_EMAIL=teacher@lectura.app
DEMO_TEACHER_PASSWORD=Lectura123!
DEMO_TEACHER_DISPLAY_NAME=Demo Teacher
