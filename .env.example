# ===============================
# Backend container configuration
# ===============================
NODE_ENV=production
TZ=UTC
PORT=3000
HOST_PORT=3010
CONTAINER_NAME=lectura-aumentada-backend
IMAGE_NAME=lectura-aumentada-backend

# ===============================
# MongoDB configuration (Option A)
# Preferred when password has special chars: use full URI URL-encoded
# Example password: P@ss/w:rd -> P%40ss%2Fw%3Ard
# ===============================
MONGODB_URI=mongodb://168.231.71.181:27017/Lectura_Aumentada_DB

# ===============================
# MongoDB configuration (Option B)
# If MONGODB_URI is empty, app builds URI from these vars.
# USER/PASSWORD are optional.
# ===============================
MONGODB_HOST=168.231.71.181
MONGODB_PORT=27017
MONGODB_DB=Lectura_Aumentada_DB
MONGODB_USER=
MONGODB_PASSWORD=

# ===============================
# JWT
# ===============================
JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=1d

# ===============================
# Demo student for local/dev auth
# Disabled automatically in production unless explicitly enabled.
# ===============================
AUTH_DEMO_SEED_ENABLED=true
DEMO_CONTENT_SEED_ENABLED=true
DEMO_STUDENT_EMAIL=student@lectura.app
DEMO_STUDENT_PASSWORD=Lectura123!
DEMO_STUDENT_DISPLAY_NAME=Demo Student
