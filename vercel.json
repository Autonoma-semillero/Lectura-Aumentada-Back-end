{
  "version": 2,
  "builds": [
    {
      "src": "api/[...all].ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "/api/health"
    },
    {
      "src": "/api-docs",
      "dest": "/api/api-docs"
    },
    {
      "src": "/(.*)",
      "dest": "/api/[...all].ts"
    }
  ]
}
