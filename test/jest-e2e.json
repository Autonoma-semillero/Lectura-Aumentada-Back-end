{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "setupFiles": ["<rootDir>/test/jest-e2e.setup.ts"],
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.json"
      }
    ]
  }
}
